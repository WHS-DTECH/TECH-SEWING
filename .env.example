# Copy this file to .env and fill in your real values.
# Never commit .env to Git — it is listed in .gitignore.

# Neon PostgreSQL connection string
# Get this from: https://console.neon.tech → your project → Connection details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# Port the local dev server listens on (Render sets PORT automatically)
PORT=3000

# Google OAuth2 app credentials (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must exactly match Google OAuth redirect URI
# Local example:  http://localhost:3000/auth/google/callback
# Render example: https://YOUR-APP.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=

# Session cookie signing secret (use a long random string)
SESSION_SECRET=replace-with-very-long-random-secret

# Optional: restrict login to your school domain
GOOGLE_WORKSPACE_DOMAIN=westlandhigh.school.nz

# Optional: comma-separated list of admin emails for admin page access
ADMIN_EMAILS=vanessapringle@westlandhigh.school.nz

# Cloudinary (recommended persistent image uploads)
# If these are set, uploads will go to Cloudinary first.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=sewing-room-activities

# Render Object Storage (S3-compatible) for persistent image uploads
# Used if Cloudinary is not configured.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
